# Database
DATABASE_URL=postgresql://qatrial:qatrial@localhost:5432/qatrial

# Authentication — required, min 32 chars of entropy
# Generate with: openssl rand -hex 48
JWT_SECRET=replace-with-openssl-rand-hex-48-at-least-32-chars

# AI Provider (optional)
AI_PROVIDER_TYPE=anthropic
AI_PROVIDER_URL=https://api.anthropic.com
