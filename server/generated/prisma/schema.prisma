datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        @default("editor")
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())
}

model Organization {
  id         String      @id @default(uuid())
  name       String
  users      User[]
  workspaces Workspace[]
  createdAt  DateTime    @default(now())
}

model Workspace {
  id        String       @id @default(uuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  projects  Project[]
  createdAt DateTime     @default(now())
}

model Project {
  id               String              @id @default(uuid())
  workspaceId      String
  workspace        Workspace           @relation(fields: [workspaceId], references: [id])
  name             String
  description      String              @default("")
  owner            String              @default("")
  version          String              @default("1.0")
  country          String              @default("")
  vertical         String?
  modules          String[]            @default([])
  type             String              @default("software")
  requirements     Requirement[]
  tests            Test[]
  risks            Risk[]
  capas            CAPA[]
  auditLogs        AuditLog[]
  evidences        Evidence[]
  approvals        Approval[]
  signatures       Signature[]
  complaints       Complaint[]
  batches          BatchRecord[]
  documents        Document[]
  pmsEntries       PMSEntry[]
  udis             UDI[]
  stabilityStudies StabilityStudy[]
  monitoringPoints MonitoringPoint[]
  auditRecords     AuditRecord[]
  changeControls   ChangeControl[]
  deviations       Deviation[]
  tasks            QTask[]
  tmfZones         TMFZone[]
  consentForms     ConsentForm[]
  submissions      SubmissionPackage[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Requirement {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  seqId         String
  title         String
  description   String   @default("")
  status        String   @default("Draft")
  tags          String[] @default([])
  riskLevel     String?
  regulatoryRef String?
  evidenceHints String[] @default([])
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Test {
  id                   String   @id @default(uuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  seqId                String
  title                String
  description          String   @default("")
  status               String   @default("Not Run")
  linkedRequirementIds String[] @default([])
  createdBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Risk {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirementId String
  severity      Int
  likelihood    Int
  detectability Int?
  riskScore     Int
  riskLevel     String
  mitigation    String?
  residualRisk  Int?
  classifiedBy  String   @default("manual")
  createdAt     DateTime @default(now())
}

model CAPA {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  status             String   @default("open")
  rootCause          String?
  containment        String?
  correctiveAction   String?
  preventiveAction   String?
  effectivenessCheck String?
  linkedTestId       String?
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())
  userId        String
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  reason        String?
}

model Evidence {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  description String   @default("")
  version     Int      @default(1)
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model Approval {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  status      String     @default("pending")
  requestedBy String
  reviewedBy  String?
  reviewedAt  DateTime?
  reason      String?
  signatureId String?    @unique
  signature   Signature? @relation(fields: [signatureId], references: [id])
  createdAt   DateTime   @default(now())
}

model Signature {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  userName   String
  userRole   String
  meaning    String
  reason     String
  method     String    @default("password")
  entityType String
  entityId   String
  timestamp  DateTime  @default(now())
  approval   Approval?
}

model Webhook {
  id            String    @id @default(uuid())
  orgId         String
  name          String
  url           String
  secret        String    @default("")
  events        String[]  @default([])
  enabled       Boolean   @default(true)
  lastTriggered DateTime?
  lastStatus    Int?
  createdAt     DateTime  @default(now())
}

model Integration {
  id         String    @id @default(uuid())
  orgId      String
  type       String
  config     Json
  enabled    Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Complaint {
  id                   String   @id @default(uuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productName          String
  reportDate           DateTime
  severity             String // minor, major, critical
  patientImpact        Boolean  @default(false)
  description          String
  reporterType         String   @default("customer") // customer, internal, regulatory, field
  investigationStatus  String   @default("received") // received, investigating, resolved, closed
  rootCause            String?
  capaId               String?
  regulatoryReportable Boolean  @default(false)
  fscaRequired         Boolean  @default(false)
  createdBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Supplier {
  id                  String               @id @default(uuid())
  orgId               String
  name                String
  category            String               @default("component") // component, service, raw_material, contract_manufacturer
  riskLevel           String               @default("medium") // low, medium, high, critical
  qualificationStatus String               @default("pending") // pending, qualified, conditional, disqualified
  overallScore        Int? // 0-100
  defectRate          Float?
  onTimeDelivery      Float?
  lastAuditDate       DateTime?
  nextAuditDate       DateTime?
  audits              SupplierAudit[]
  portalLinks         SupplierPortalLink[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model SupplierPortalLink {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  token      String   @unique @default(uuid())
  expiresAt  DateTime
  createdBy  String
  createdAt  DateTime @default(now())
}

model SupplierAudit {
  id            String    @id @default(uuid())
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  auditDate     DateTime
  auditType     String    @default("routine") // routine, for_cause, re_qualification
  findings      String?
  score         Int? // 0-100
  auditor       String
  status        String    @default("scheduled") // scheduled, in_progress, completed, cancelled
  nextAuditDate DateTime?
  createdAt     DateTime  @default(now())
}

model BatchRecord {
  id            String      @id @default(uuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productName   String
  batchNumber   String
  status        String      @default("draft") // draft, in_progress, review, released, rejected
  startDate     DateTime?
  endDate       DateTime?
  yieldActual   Float?
  yieldExpected Float?
  releasedBy    String?
  releasedAt    DateTime?
  steps         BatchStep[]
  createdBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model BatchStep {
  id            String      @id @default(uuid())
  batchId       String
  batch         BatchRecord @relation(fields: [batchId], references: [id], onDelete: Cascade)
  stepNumber    Int
  instruction   String
  expectedValue String?
  actualValue   String?
  unit          String?
  inSpec        Boolean?
  deviation     Boolean     @default(false)
  deviationNote String?
  performedBy   String?
  performedAt   DateTime?
  verifiedBy    String?
  createdAt     DateTime    @default(now())
}

model TrainingPlan {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  role        String
  description String   @default("")
  courses     String[] @default([]) // course IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id               String           @id @default(uuid())
  orgId            String
  title            String
  description      String           @default("")
  linkedDocumentId String?
  version          String           @default("1.0")
  durationMinutes  Int?
  records          TrainingRecord[]
  quizzes          Quiz[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model TrainingRecord {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedAt DateTime?
  score       Int? // 0-100 percentage
  status      String    @default("assigned") // assigned, in_progress, completed, expired
  validUntil  DateTime?
  assignedAt  DateTime  @default(now())
}

model Document {
  id             String                 @id @default(uuid())
  projectId      String
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  type           String                 @default("sop") // sop, work_instruction, policy, form, specification
  currentVersion String                 @default("1.0")
  status         String                 @default("draft") // draft, in_review, approved, effective, superseded, retired
  versions       DocumentVersion[]
  distributions  DocumentDistribution[]
  createdBy      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model DocumentVersion {
  id            String    @id @default(uuid())
  documentId    String
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version       String
  content       String    @default("")
  changeReason  String?
  author        String
  reviewedBy    String?
  approvedBy    String?
  effectiveDate DateTime?
  createdAt     DateTime  @default(now())
}

model ComputerizedSystem {
  id               String           @id @default(uuid())
  orgId            String
  name             String
  vendor           String           @default("")
  version          String           @default("")
  gampCategory     Int              @default(4)
  validationStatus String           @default("planned")
  riskLevel        String           @default("medium")
  description      String           @default("")
  lastReviewDate   DateTime?
  nextReviewDate   DateTime?
  retiredDate      DateTime?
  reviews          PeriodicReview[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model PeriodicReview {
  id                String             @id @default(uuid())
  systemId          String
  system            ComputerizedSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  reviewDate        DateTime
  reviewer          String
  status            String             @default("scheduled")
  stillInUse        Boolean            @default(true)
  changesNoted      String?
  incidentsNoted    String?
  regulatoryChanges String?
  accessReviewed    Boolean            @default(false)
  findings          String?
  nextReviewDate    DateTime?
  createdAt         DateTime           @default(now())
}

model PMSEntry {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entryType      String
  title          String
  description    String   @default("")
  source         String   @default("")
  date           DateTime @default(now())
  severity       String?
  actionTaken    String?
  linkedEntityId String?
  createdBy      String?
  createdAt      DateTime @default(now())
}

model UDI {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deviceIdentifier  String
  productionId      String?
  productName       String
  deviceDescription String   @default("")
  brandName         String   @default("")
  versionModelNo    String   @default("")
  companyName       String   @default("")
  gudidSubmitted    Boolean  @default(false)
  eudamedRegistered Boolean  @default(false)
  labelContent      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model StabilityStudy {
  id             String            @id @default(uuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productName    String
  studyType      String            @default("long_term")
  conditions     String
  startDate      DateTime
  durationMonths Int
  pullSchedule   String            @default("")
  status         String            @default("active")
  samples        StabilitySample[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model StabilitySample {
  id              String         @id @default(uuid())
  studyId         String
  study           StabilityStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  timePointMonths Int
  testDate        DateTime?
  parameter       String
  result          String?
  specification   String?
  inSpec          Boolean?
  oosFlag         Boolean        @default(false)
  ootFlag         Boolean        @default(false)
  investigationId String?
  createdAt       DateTime       @default(now())
}

model WorkflowTemplate {
  id          String              @id @default(uuid())
  orgId       String
  name        String
  description String              @default("")
  entityType  String
  enabled     Boolean             @default(true)
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model WorkflowStep {
  id                String           @id @default(uuid())
  templateId        String
  template          WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order             Int
  name              String
  type              String           @default("approval")
  assigneeRole      String           @default("qa_manager")
  requiredApprovers Int              @default(1)
  slaHours          Int?
  escalateTo        String?
  conditions        Json?
  logic             String           @default("and") // and, or — for parallel approvals
  skipCondition     Json? // { field, operator, value } — skip step if condition met
  rejectAction      String           @default("cancel") // cancel, restart, goto_step
  rejectTarget      Int? // step order to go back to on reject
  createdAt         DateTime         @default(now())
}

model WorkflowExecution {
  id           String           @id @default(uuid())
  templateId   String
  template     WorkflowTemplate @relation(fields: [templateId], references: [id])
  entityType   String
  entityId     String
  projectId    String
  currentStep  Int              @default(0)
  status       String           @default("active")
  restartCount Int              @default(0)
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  actions      WorkflowAction[]
}

model WorkflowAction {
  id          String            @id @default(uuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepOrder   Int
  userId      String
  userName    String
  action      String
  reason      String?
  delegatedTo String?
  timestamp   DateTime          @default(now())
}

model ChangeControl {
  id                     String       @id @default(uuid())
  projectId              String
  project                Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                  String
  changeNumber           String
  type                   String       @default("document")
  description            String       @default("")
  justification          String       @default("")
  status                 String       @default("initiated")
  riskLevel              String       @default("medium")
  initiatedBy            String
  impactAssessment       String?
  affectedDocuments      String[]     @default([])
  affectedTraining       String[]     @default([])
  affectedValidation     String[]     @default([])
  workflowExecutionId    String?
  effectivenessCheckDate DateTime?
  effectivenessVerified  Boolean      @default(false)
  tasks                  ChangeTask[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model ChangeTask {
  id              String        @id @default(uuid())
  changeControlId String
  changeControl   ChangeControl @relation(fields: [changeControlId], references: [id], onDelete: Cascade)
  title           String
  assignee        String
  dueDate         DateTime?
  status          String        @default("open")
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
}

model Deviation {
  id                  String    @id @default(uuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deviationNumber     String
  title               String
  classification      String    @default("minor")
  area                String    @default("")
  description         String    @default("")
  detectedBy          String
  detectedAt          DateTime  @default(now())
  status              String    @default("detected")
  investigationMethod String?
  investigationNotes  String?
  rootCause           String?
  capaId              String?
  closedBy            String?
  closedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model MonitoringPoint {
  id              String              @id @default(uuid())
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  zone            String
  type            String              @default("temperature")
  unit            String              @default("°C")
  alertThreshold  Float?
  actionThreshold Float?
  readings        MonitoringReading[]
  createdAt       DateTime            @default(now())
}

model MonitoringReading {
  id             String          @id @default(uuid())
  pointId        String
  point          MonitoringPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)
  value          Float
  timestamp      DateTime        @default(now())
  excursion      Boolean         @default(false)
  excursionType  String?
  actionTaken    String?
  acknowledgedBy String?
}

model AuditRecord {
  id            String         @id @default(uuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          String         @default("internal")
  title         String
  scheduledDate DateTime
  actualDate    DateTime?
  status        String         @default("scheduled")
  scope         String         @default("")
  leadAuditor   String
  findings      AuditFinding[]
  reportSummary String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AuditFinding {
  id               String      @id @default(uuid())
  auditId          String
  audit            AuditRecord @relation(fields: [auditId], references: [id], onDelete: Cascade)
  classification   String
  area             String
  description      String
  responsibleParty String?
  dueDate          DateTime?
  capaId           String?
  status           String      @default("open")
  response         String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  type       String // approval_needed, task_overdue, capa_deadline, deviation_opened, workflow_escalation, comment_mention, document_review, training_due
  title      String
  message    String   @default("")
  entityType String?
  entityId   String?
  projectId  String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Comment {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  projectId  String
  userId     String
  userName   String
  content    String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QTask {
  id           String    @id @default(uuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String    @default("")
  assigneeId   String
  assigneeName String    @default("")
  dueDate      DateTime?
  priority     String    @default("medium")
  status       String    @default("open")
  entityType   String?
  entityId     String?
  createdBy    String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
}

model CustomDashboard {
  id          String            @id @default(uuid())
  orgId       String
  name        String
  description String            @default("")
  createdBy   String
  isPublic    Boolean           @default(true)
  widgets     DashboardWidget[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model DashboardWidget {
  id          String          @id @default(uuid())
  dashboardId String
  dashboard   CustomDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type        String // counter, trend, bar, pie, table, gauge
  title       String
  dataSource  String // requirements, tests, capa, deviations, complaints, training, suppliers, batches, stability
  metric      String // count, pass_rate, avg_score, compliance_pct, overdue_count, yield_avg, oos_count
  groupBy     String? // status, severity, area, classification, month, product
  filters     Json? // { projectId?, dateRange?, area? }
  position    Int             @default(0)
  size        String          @default("medium") // small, medium, large
  createdAt   DateTime        @default(now())
}

// ── Form Builder ────────────────────────────────────────────────────────────

model FormTemplate {
  id          String           @id @default(uuid())
  orgId       String
  name        String
  description String           @default("")
  entityType  String           @default("custom") // deviation_investigation, complaint_intake, audit_checklist, custom
  fields      FormField[]
  submissions FormSubmission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model FormField {
  id          String       @id @default(uuid())
  templateId  String
  template    FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order       Int
  label       String
  type        String // text, textarea, number, date, select, multi_select, checkbox, radio, file, signature, section_header
  required    Boolean      @default(false)
  options     Json? // for select/radio: ["Option A", "Option B"]
  placeholder String?
  helpText    String?
  validation  Json? // { min?, max?, pattern?, minLength?, maxLength? }
  conditional Json? // { dependsOnField: id, showWhen: value }
  createdAt   DateTime     @default(now())
}

model FormSubmission {
  id          String       @id @default(uuid())
  templateId  String
  template    FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  projectId   String
  entityType  String?
  entityId    String?
  data        Json // { fieldId: value, ... }
  submittedBy String
  status      String       @default("submitted") // submitted, reviewed, approved
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ── Realtime Presence ───────────────────────────────────────────────────────

model PresenceRecord {
  id         String   @id @default(uuid())
  userId     String
  userName   String
  projectId  String
  entityType String?
  entityId   String?
  lastSeen   DateTime @default(now())
}

// ── eTMF (Electronic Trial Master File) ──────────────────────────────────────

model TMFZone {
  id        String       @id @default(uuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number    Int
  name      String
  sections  TMFSection[]
  createdAt DateTime     @default(now())
}

model TMFSection {
  id        String        @id @default(uuid())
  zoneId    String
  zone      TMFZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  number    String
  name      String
  artifacts TMFArtifact[]
  createdAt DateTime      @default(now())
}

model TMFArtifact {
  id             String     @id @default(uuid())
  sectionId      String
  section        TMFSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name           String
  fileName       String?
  fileSize       Int?
  storagePath    String?
  status         String     @default("expected")
  retentionYears Int        @default(25)
  uploadedBy     String?
  uploadedAt     DateTime?
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ── eConsent ─────────────────────────────────────────────────────────────────

model ConsentForm {
  id                     String             @id @default(uuid())
  projectId              String
  project                Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                  String
  version                String             @default("1.0")
  status                 String             @default("draft")
  content                String             @default("")
  language               String             @default("en")
  comprehensionQuestions Json?
  requireComprehension   Boolean            @default(true)
  reconsentOnAmendment   Boolean            @default(true)
  signatures             ConsentSignature[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model ConsentSignature {
  id                  String      @id @default(uuid())
  consentFormId       String
  consentForm         ConsentForm @relation(fields: [consentFormId], references: [id], onDelete: Cascade)
  subjectId           String
  signedAt            DateTime    @default(now())
  comprehensionScore  Int?
  comprehensionPassed Boolean     @default(true)
  withdrawnAt         DateTime?
  withdrawalReason    String?
  witnessName         String?
  witnessSignedAt     DateTime?
  method              String      @default("electronic")
  ipAddress           String?
  createdAt           DateTime    @default(now())
}

// ── Submission Builder ──────────────────────────────────────────────────────

model SubmissionPackage {
  id              String    @id @default(uuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            String // fda_510k, eu_mdr_td, pmda_sted, ectd_module3
  title           String
  status          String    @default("draft") // draft, in_progress, review, submitted
  targetAuthority String // FDA, EMA, PMDA, Notified Body
  sections        Json // structured sections with content
  generatedAt     DateTime?
  submittedAt     DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── Scheduled Reports ───────────────────────────────────────────────────────

model ScheduledReport {
  id         String    @id @default(uuid())
  orgId      String
  projectId  String
  reportType String // validation_summary, executive_brief, gap_analysis, risk_assessment, traceability
  schedule   String // cron expression: "0 8 * * 1" = every Monday 8am
  recipients String[]  @default([])
  format     String    @default("html") // html, pdf
  enabled    Boolean   @default(true)
  lastRunAt  DateTime?
  lastStatus String?
  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ── Quiz Builder ────────────────────────────────────────────────────────────

model Quiz {
  id           String         @id @default(uuid())
  courseId     String
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  passingScore Int            @default(80)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  createdAt    DateTime       @default(now())
}

model QuizQuestion {
  id             String   @id @default(uuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order          Int
  question       String
  type           String   @default("multiple_choice") // multiple_choice, true_false, multi_select
  options        Json // ["Option A", "Option B", "Option C", "Option D"]
  correctAnswers Json // [0] for single, [0, 2] for multi_select
  explanation    String?
  createdAt      DateTime @default(now())
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  answers     Json // { questionId: selectedIndex[] }
  score       Int // percentage
  passed      Boolean
  completedAt DateTime @default(now())
}

// ── Document Distribution ───────────────────────────────────────────────────

model DocumentDistribution {
  id             String    @id @default(uuid())
  documentId     String
  document       Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  distributedAt  DateTime  @default(now())
  acknowledgedAt DateTime?
  version        String
}
