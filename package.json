{
  "name": "qatrial",
  "private": true,
  "version": "3.0.0",
  "description": "Open-source AI-powered quality management platform for regulated industries. Country-aware, GxP-aware, with compliance co-pilot.",
  "license": "AGPL-3.0-only",
  "author": "MeyerThorsten",
  "repository": {
    "type": "git",
    "url": "https://github.com/MeyerThorsten/QAtrial.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:server": "vitest run server/app.contract.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "server": "tsx server/index.ts",
    "server:dev": "tsx watch server/index.ts",
    "db:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:push": "prisma db push --schema=server/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=server/prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@prisma/client": "^7.6.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "hono": "^4.12.10",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "recharts": "^3.8.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
